---
import Cursor from '../components/Cursor.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&family=Fraunces:ital,opsz,wght@0,9..144,300;1,9..144,300;1,9..144,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Ambient glow — haut droite -->
    <div aria-hidden="true" style="position: fixed; top: -100px; right: -100px; width: 700px; height: 700px; background: radial-gradient(ellipse at top right, rgba(232, 164, 74, 0.1) 0%, transparent 60%); filter: blur(120px); pointer-events: none; z-index: 0;"></div>
    <!-- Ambient glow — milieu gauche -->
    <div aria-hidden="true" style="position: fixed; top: 50%; left: -150px; transform: translateY(-50%); width: 600px; height: 600px; background: radial-gradient(ellipse at left, rgba(232, 164, 74, 0.1) 0%, transparent 65%); filter: blur(120px); pointer-events: none; z-index: 0;"></div>
    <Cursor />
    <slot />
    <script src="../scripts/lenis.ts"></script>
    <script src="../scripts/animations.ts"></script>
    <script src="../scripts/cursor.ts"></script>
    <script src="../scripts/tilt.ts"></script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
