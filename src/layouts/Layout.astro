---
import Cursor from '../components/Cursor.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = '/images/og-image.jpg' } = Astro.props;
const siteUrl = 'https://robincarivenc.fr';
const canonicalUrl = Astro.url ? `${siteUrl}${Astro.url.pathname}` : siteUrl;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO de base -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Robin Carivenc" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Robin Carivenc — Développeur Web Freelance" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- JSON-LD LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Robin Carivenc — Développeur Web Freelance",
      "description": "Sites web sur-mesure pour artisans et entreprises locales. Design moderne, SEO local, livraison rapide. Basé en Alsace.",
      "url": siteUrl,
      "areaServed": [
        { "@type": "State", "name": "Alsace" },
        { "@type": "Country", "name": "France" }
      ],
      "priceRange": "€€",
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "availableLanguage": "French"
      }
    })} />

    <!-- Polices -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&family=Fraunces:ital,opsz,wght@0,9..144,300;1,9..144,300;1,9..144,400&family=Caveat:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Ambient glow — haut droite -->
    <div class="ambient-glow-1" aria-hidden="true"></div>
    <!-- Ambient glow — milieu gauche -->
    <div class="ambient-glow-2" aria-hidden="true"></div>
    <Cursor />
    <slot />
    <script src="../scripts/lenis.ts"></script>
    <script src="../scripts/animations.ts"></script>
    <script src="../scripts/lottie.ts"></script>
    <script src="../scripts/cursor.ts"></script>
    <script src="../scripts/tilt.ts"></script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  @keyframes breathe {
    0%, 100% { opacity: 0.1; transform: scale(1); }
    50%       { opacity: 0.18; transform: scale(1.08); }
  }

  .ambient-glow-1 {
    position: fixed;
    top: -100px;
    right: -100px;
    width: 700px;
    height: 700px;
    background: radial-gradient(ellipse at top right, rgba(91, 150, 245, 0.12) 0%, transparent 60%);
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
    animation: breathe 12s ease-in-out infinite;
    will-change: transform, opacity;
  }

  .ambient-glow-2 {
    position: fixed;
    top: 50%;
    left: -150px;
    transform: translateY(-50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(ellipse at left, rgba(91, 150, 245, 0.1) 0%, transparent 65%);
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
    animation: breathe 16s ease-in-out infinite reverse;
    will-change: transform, opacity;
  }
</style>
