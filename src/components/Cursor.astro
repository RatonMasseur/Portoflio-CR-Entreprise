<div id="cursor-dot" class="fixed top-0 left-0 pointer-events-none z-[9999]"></div>
<div id="cursor-ring" class="fixed top-0 left-0 pointer-events-none z-[9998]"></div>

<style>
  @media (hover: none), (pointer: coarse) {
    #cursor-dot, #cursor-ring { display: none !important; }
  }
  @media (hover: hover) {
    * { cursor: none !important; }
  }

  #cursor-dot {
    width: 7px;
    height: 7px;
    background: var(--accent-primary, #2060d8);
    border-radius: 50%;
    box-shadow: 0 0 8px rgba(32, 96, 216, 0.7);
    transition: transform 0.12s ease, opacity 0.2s ease, width 0.2s ease, height 0.2s ease;
  }

  #cursor-ring {
    width: 34px;
    height: 34px;
    border: 1.5px solid rgba(32, 96, 216, 0.45);
    border-radius: 50%;
    transition: width 0.28s cubic-bezier(0.34, 1.56, 0.64, 1),
                height 0.28s cubic-bezier(0.34, 1.56, 0.64, 1),
                border-color 0.25s ease,
                background 0.25s ease,
                border-radius 0.25s ease;
  }

  /* État hover liens/boutons — ring se remplit légèrement */
  #cursor-ring.is-hovering {
    width: 46px;
    height: 46px;
    border-color: rgba(32, 96, 216, 0.7);
    background: rgba(32, 96, 216, 0.08);
  }

  /* État hover cards projets — ring devient un sélecteur carré */
  #cursor-ring.is-viewing {
    width: 52px;
    height: 52px;
    border-color: rgba(32, 96, 216, 0.8);
    border-radius: 8px;
    background: rgba(32, 96, 216, 0.1);
  }

  /* Dot disparaît sur les sections dark (spotlight suffit) */
  #cursor-dot.on-dark {
    box-shadow: 0 0 12px rgba(32, 96, 216, 0.9), 0 0 24px rgba(32, 96, 216, 0.4);
  }
</style>
