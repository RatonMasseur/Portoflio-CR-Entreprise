---
import HeroBackground from './HeroBackground.tsx';
---
<section class="relative min-h-screen flex items-end px-6 pt-36 pb-20" style="background: #0a0806;" data-dark-section>

  <!-- Clip container pour les orbs (overflow-hidden ici, pas sur la section) -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <!-- MeshGradient React (paper-design/shaders) -->
    <HeroBackground client:only="react" />
    <!-- Grille perspective animée -->
    <div class="hero-grid"></div>
    <!-- Grain dédié fond dark — overlay visible sur noir, contrairement au multiply global -->
    <div class="grain-hero"></div>
  </div>

  <div class="relative w-full max-w-6xl mx-auto" style="z-index: 3;">

    <!-- Top label row -->
    <div class="flex items-center gap-4 mb-12" data-animate="fade-up">
      <span class="section-label">Développeur Web Freelance · Alsace</span>
      <div class="h-px flex-1 max-w-[60px]" style="background: rgba(255,255,255,0.12);"></div>
      <span class="w-2 h-2 rounded-full" style="background: var(--accent-primary); box-shadow: 0 0 10px rgba(32,96,216,0.6);"></span>
      <span class="label-tech" style="color: rgba(255,255,255,0.45);">Disponible</span>
    </div>

    <!-- Main headline -->
    <div id="hero-headline" class="mb-10">
      <h1 class="font-['Bricolage_Grotesque'] leading-[0.92] tracking-tight" style="font-size: var(--type-display); font-weight: 800; color: #ffffff;">
        Pas une agence.<br />
        Pas un template.
      </h1>
      <div class="flex items-baseline gap-4 mt-3">
        <h1 class="font-['Bricolage_Grotesque'] leading-[0.92] tracking-tight italic" style="font-size: var(--type-display); font-weight: 800; color: var(--accent-light);">
          <span class="hero-badge-outline">Votre site.</span>
        </h1>
      </div>
    </div>

    <!-- Bottom row: description + CTA + stats -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-10" data-animate="fade-up" data-animate-delay="180">

      <div class="max-w-md">
        <p class="text-lg leading-relaxed mb-8" style="color: rgba(255,255,255,0.58);">
          Un site professionnel qui vous ressemble, conçu pour convertir vos visiteurs en clients. Livré en 7 jours.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#contact" class="btn-primary">
            <span>Parlons de votre projet</span>
            <span class="btn-arrow-icon btn-arrow-light">
              <span class="btn-arrow-inner">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" stroke="#2060d8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" stroke="#2060d8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </span>
          </a>
          <a href="#realisations" class="btn-outline-dark">
            <span>Voir mes réalisations</span>
            <span class="btn-arrow-icon btn-arrow-white">
              <span class="btn-arrow-inner">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" stroke="rgba(255,255,255,0.85)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" stroke="rgba(255,255,255,0.85)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </span>
          </a>
        </div>
        <p class="mt-6 label-tech" style="color: rgba(255,255,255,0.35);">
          Disponible pour nouveaux projets · Délai garanti
        </p>
      </div>

    </div>

    <!-- Scroll indicator -->
    <div class="absolute right-0 bottom-0 hidden lg:flex flex-col items-center gap-3" data-animate="fade-up" data-animate-delay="300">
      <p class="label-tech" style="writing-mode: vertical-rl; color: rgba(255,255,255,0.3);">Découvrir</p>
      <div class="w-px h-12" style="background: linear-gradient(to bottom, rgba(255,255,255,0.2), transparent);"></div>
    </div>

  </div>
</section>

<style>
  /* ─── Grille perspective — plancher animé ─── */
  .hero-grid {
    position: absolute;
    bottom: -10%;
    left: 50%;
    width: 240%;
    height: 75%;
    transform: translateX(-50%) perspective(700px) rotateX(58deg);
    transform-origin: center bottom;
    background-image:
      linear-gradient(rgba(32, 96, 216, 0.18) 1px, transparent 1px),
      linear-gradient(90deg, rgba(32, 96, 216, 0.18) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 65%);
    -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 65%);
    animation: grid-flow 5s linear infinite;
  }

  @keyframes grid-flow {
    from { background-position: 0 0; }
    to   { background-position: 0 80px; }
  }

  /* Grain dédié fond dark — overlay (visible sur noir, contrairement à multiply) */
  .grain-hero {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px;
    opacity: 0.07;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  /* Badge outline style "AI Communities" sur "Votre site." */
  .hero-badge-outline {
    display: inline-block;
    border: 1.5px solid rgba(91, 150, 245, 0.55);
    border-radius: 6px;
    padding: 0 14px 2px;
    box-shadow: 0 0 20px rgba(32, 96, 216, 0.2);
  }

  /* btn-outline adapté fond dark */
  .btn-outline-dark {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 28px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.8);
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    border-radius: 100px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    min-height: 44px;
  }

  .btn-outline-dark:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.4);
    transform: translateY(-2px);
  }
</style>
