---
const testimonials = [
  { quote: "Robin a parfaitement compris ce que je voulais. Mon site était en ligne en une semaine, exactement comme promis.", name: "Marie", role: "Fleuriste" },
  { quote: "Très professionnel et réactif. Je recommande à tous les artisans qui veulent un vrai site.", name: "Thomas", role: "Menuisier" },
  { quote: "Depuis que j'ai mon site, je reçois des appels de nouveaux clients chaque semaine. Ça change tout.", name: "Sophie", role: "Coiffeuse" },
  { quote: "Je n'y connaissais rien en informatique. Robin m'a tout expliqué simplement. Le résultat est top.", name: "Philippe", role: "Électricien" }
];
---

<section class="px-6 overflow-hidden" style="background: var(--bg-primary);" data-dark-section>
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16" data-animate="fade-up">
      <div>
        <span class="section-label mb-4 block">Témoignages</span>
        <h2 class="font-['Bricolage_Grotesque'] leading-tight" style="font-size: var(--type-h2); font-weight: 700; color: #ffffff;">Ce que disent<br /><span style="color: var(--accent-light);">mes clients</span></h2>
      </div>
      <div class="hidden md:flex gap-2 items-center" id="testimonial-dots-desktop">
        {testimonials.map((_, i) => (
          <button
            class="testimonial-dot-btn h-1.5 rounded-full transition-all duration-300 cursor-pointer"
            style={i === 0 ? 'background: var(--accent-primary); width: 24px;' : 'background: rgba(255,255,255,0.18); width: 8px;'}
            data-dot={i}
            aria-label={`Témoignage ${i + 1}`}
          ></button>
        ))}
      </div>
    </div>

    <div class="relative" data-animate="fade-up">
      <div class="overflow-hidden" id="testimonial-viewport">
        <div class="flex transition-transform duration-500 ease-out" id="testimonial-track">
          {testimonials.map((t) => (
            <div class="w-full md:w-1/2 shrink-0 px-2.5">
              <div class="testimonial-card p-7 h-full relative" style="border-radius: 16px;">
                <!-- Guillemet décoratif serif -->
                <div class="font-['Fraunces'] italic leading-none mb-3 select-none" style="font-size: 5rem; font-weight: 300; color: var(--accent-light); opacity: 0.3; line-height: 1;">"</div>
                <!-- Citation -->
                <p class="text-base mb-6 leading-relaxed" style="color: rgba(255,255,255,0.72);">{t.quote}</p>
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-full flex items-center justify-center font-['Bricolage_Grotesque'] font-bold text-sm shrink-0" style="background: rgba(59,130,246,0.15); color: var(--accent-light); border: 1px solid rgba(59,130,246,0.25);">
                    {t.name[0]}
                  </div>
                  <div>
                    <p class="text-sm font-['Bricolage_Grotesque'] font-bold" style="color: #ffffff;">{t.name}</p>
                    <p class="label-tech" style="color: var(--accent-light);">{t.role}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Mobile dots -->
      <div class="flex justify-center gap-2 mt-8 md:hidden" id="testimonial-dots">
        {testimonials.map((_, i) => (
          <button
            class="testimonial-dot-btn h-1.5 rounded-full transition-all duration-300 cursor-pointer"
            style={i === 0 ? 'background: var(--accent-primary); width: 24px;' : 'background: rgba(255,255,255,0.18); width: 8px;'}
            data-dot={i}
            aria-label={`Témoignage ${i + 1}`}
          ></button>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .testimonial-card {
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
    transition: border-color 0.3s ease-in-out, background 0.3s ease-in-out;
  }

  .testimonial-card:hover {
    background: rgba(91, 150, 245, 0.06);
    border-color: rgba(91, 150, 245, 0.25);
  }
</style>

<script src="../scripts/testimonials.ts"></script>
