---
const testimonials = [
  { quote: "Robin a parfaitement compris ce que je voulais. Mon site était en ligne en une semaine, exactement comme promis.", name: "Marie", role: "Fleuriste" },
  { quote: "Très professionnel et réactif. Je recommande à tous les artisans qui veulent un vrai site.", name: "Thomas", role: "Menuisier" },
  { quote: "Depuis que j'ai mon site, je reçois des appels de nouveaux clients chaque semaine. Ça change tout.", name: "Sophie", role: "Coiffeuse" },
  { quote: "Je n'y connaissais rien en informatique. Robin m'a tout expliqué simplement. Le résultat est top.", name: "Philippe", role: "Électricien" }
];
---

<section class="py-32 md:py-20 px-6 overflow-hidden">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16" data-animate="fade-up">
      <div>
        <span class="section-label mb-4 block">Témoignages</span>
        <h2 class="font-['Bricolage_Grotesque'] leading-tight" style="font-size: var(--type-h2); font-weight: 700;">Ce que disent<br />mes clients</h2>
      </div>
      <div class="hidden md:flex gap-2 items-center" id="testimonial-dots-desktop">
        {testimonials.map((_, i) => (
          <button
            class="testimonial-dot-btn h-1.5 rounded-full transition-all duration-300 cursor-pointer"
            style={i === 0 ? 'background: var(--accent-primary); width: 24px;' : 'background: var(--border-card); width: 8px; border: 1px solid rgba(0,0,0,0.1);'}
            data-dot={i}
            aria-label={`Témoignage ${i + 1}`}
          ></button>
        ))}
      </div>
    </div>

    <div class="relative" data-animate="fade-up">
      <div class="overflow-hidden" id="testimonial-viewport">
        <div class="flex transition-transform duration-500 ease-out" id="testimonial-track">
          {testimonials.map((t) => (
            <div class="w-full md:w-1/2 shrink-0 px-2.5">
              <div class="p-7 h-full relative glass" style="border-radius: 16px; box-shadow: 0 4px 32px rgba(32, 96, 216, 0.12), inset 0 1px 0 rgba(255,255,255,0.9);">
                <!-- Guillemet décoratif serif -->
                <div class="font-['Fraunces'] italic leading-none mb-3 select-none" style="font-size: 5rem; font-weight: 300; color: var(--accent-primary); opacity: 0.25; line-height: 1;">"</div>
                <!-- Citation en Fraunces -->
                <p class="quote-serif text-base mb-6">{t.quote}</p>
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-full flex items-center justify-center font-['Bricolage_Grotesque'] font-bold text-sm shrink-0" style="background: rgba(32,96,216,0.12); color: var(--accent-primary); border: 1px solid rgba(32,96,216,0.2);">
                    {t.name[0]}
                  </div>
                  <div>
                    <p class="text-sm font-['Bricolage_Grotesque'] font-bold" style="color: var(--text-primary);">{t.name}</p>
                    <p class="label-tech" style="color: var(--accent-primary);">{t.role}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Mobile dots -->
      <div class="flex justify-center gap-2 mt-8 md:hidden" id="testimonial-dots">
        {testimonials.map((_, i) => (
          <button
            class="testimonial-dot-btn h-1.5 rounded-full transition-all duration-300 cursor-pointer"
            style={i === 0 ? 'background: var(--accent-primary); width: 24px;' : 'background: var(--border-card); width: 8px;'}
            data-dot={i}
            aria-label={`Témoignage ${i + 1}`}
          ></button>
        ))}
      </div>
    </div>

  </div>
</section>

<script src="../scripts/testimonials.ts"></script>
