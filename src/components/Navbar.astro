<nav
  id="navbar"
  class="fixed z-50 transition-all duration-500"
  style="top: 16px; left: 50%; transform: translateX(-50%); width: calc(100% - 48px); max-width: 960px;"
>
  <div
    id="navbar-inner"
    class="flex items-center justify-between px-5 py-2.5 transition-all duration-500 relative"
    style="border-radius: 100px;"
  >
    <!-- Glass background layer — filter appliqué ici, pas sur le contenu texte -->
    <div
      id="navbar-bg"
      class="absolute inset-0 transition-all duration-500"
      style="border-radius: 100px; background: rgba(255,255,255,0.06); backdrop-filter: blur(32px) saturate(200%); -webkit-backdrop-filter: blur(32px) saturate(200%); box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), inset 0 -1px 0 rgba(255,255,255,0.05), 0 8px 40px rgba(0,0,0,0.15), 0 2px 8px rgba(0,0,0,0.1), inset 0 0 0 1px rgba(255,255,255,0.15);"
    ></div>

    <!-- Logo -->
    <a href="#" class="shrink-0 relative z-10">
      <img src="/images/logo-white.webp" alt="Robin Carivenc" style="height: 52px; width: auto;" />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6 text-[13px] relative z-10" style="color: rgba(255,255,255,0.85);">
      <a href="#services" class="nav-link hover:text-white transition-colors duration-200 tracking-wide">Services</a>
      <a href="#realisations" class="nav-link hover:text-white transition-colors duration-200 tracking-wide">Réalisations</a>
      <a href="#a-propos" class="nav-link hover:text-white transition-colors duration-200 tracking-wide">À propos</a>
      <a href="#processus" class="nav-link hover:text-white transition-colors duration-200 tracking-wide">Processus</a>
      <a href="#faq" class="nav-link hover:text-white transition-colors duration-200 tracking-wide">FAQ</a>
    </div>

    <!-- CTA animé -->
    <a
      href="#contact"
      class="contact-nav-btn hidden md:flex items-center gap-2 shrink-0 z-10"
    >
      <span>Contact</span>
      <span class="contact-nav-arrow-icon">
        <span class="contact-nav-arrow-inner">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </span>
    </a>

    <!-- Mobile toggle -->
    <button id="menu-toggle" class="md:hidden flex flex-col gap-[5px] p-2 cursor-pointer relative z-10" aria-label="Ouvrir le menu">
      <span class="block w-[18px] h-[1.5px] bg-white transition-all duration-300 origin-center" id="bar1"></span>
      <span class="block w-[18px] h-[1.5px] bg-white transition-all duration-300" id="bar2"></span>
      <span class="block w-[18px] h-[1.5px] bg-white transition-all duration-300 origin-center" id="bar3"></span>
    </button>
  </div>
</nav>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 flex flex-col items-center justify-center gap-8 text-2xl opacity-0 pointer-events-none transition-opacity duration-300"
  style="background: rgba(10, 8, 6, 0.97); backdrop-filter: blur(24px);"
>
  <a href="#services" class="mobile-link font-['Bricolage_Grotesque'] font-bold text-white hover:text-[var(--accent-light)] transition-colors">Services</a>
  <a href="#realisations" class="mobile-link font-['Bricolage_Grotesque'] font-bold text-white hover:text-[var(--accent-light)] transition-colors">Réalisations</a>
  <a href="#a-propos" class="mobile-link font-['Bricolage_Grotesque'] font-bold text-white hover:text-[var(--accent-light)] transition-colors">À propos</a>
  <a href="#processus" class="mobile-link font-['Bricolage_Grotesque'] font-bold text-white hover:text-[var(--accent-light)] transition-colors">Processus</a>
  <a href="#faq" class="mobile-link font-['Bricolage_Grotesque'] font-bold text-white hover:text-[var(--accent-light)] transition-colors">FAQ</a>
  <a href="#contact" class="mobile-link mt-4 text-base font-semibold font-['Bricolage_Grotesque'] px-6 py-3 rounded-full" style="background: var(--gradient-cta); color: #fff;">Contact →</a>
</div>

<style>
  /* ── Bouton Contact animé ── */
  .contact-nav-btn {
    background: var(--gradient-cta);
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    font-family: 'Bricolage Grotesque', sans-serif;
    letter-spacing: 0.02em;
    padding: 6px 8px 6px 16px;
    border-radius: 100px;
    text-decoration: none;
    min-height: 34px;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .contact-nav-arrow-icon {
    position: relative;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.22);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact-nav-arrow-inner {
    position: absolute;
    inset: 0;
    display: grid;
    place-content: center;
    transition: transform 0.22s ease;
  }

  .contact-nav-arrow-inner svg:last-child {
    margin-top: 2px;
    transform: translateX(-18px);
  }

  /* ── Nav link active ── */
  .nav-link.is-active {
    font-weight: 700;
    color: #ffffff !important;
  }
</style>

<script>
  const navbarBg = document.getElementById('navbar-bg')!;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      navbarBg.style.background = 'rgba(255,255,255,0.10)';
      navbarBg.style.boxShadow = 'inset 0 1px 0 rgba(255,255,255,0.25), 0 8px 40px rgba(0,0,0,0.2), inset 0 0 0 1px rgba(255,255,255,0.20)';
    } else {
      navbarBg.style.background = 'rgba(255,255,255,0.06)';
      navbarBg.style.boxShadow = 'inset 0 1px 0 rgba(255,255,255,0.2), inset 0 -1px 0 rgba(255,255,255,0.05), 0 8px 40px rgba(0,0,0,0.15), 0 2px 8px rgba(0,0,0,0.1), inset 0 0 0 1px rgba(255,255,255,0.15)';
    }
  });

  // ── Mobile menu ──
  const toggle = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  const bar3 = document.getElementById('bar3')!;
  let open = false;

  toggle.addEventListener('click', () => {
    open = !open;
    mobileMenu.style.opacity = open ? '1' : '0';
    mobileMenu.style.pointerEvents = open ? 'all' : 'none';
    bar1.style.transform = open ? 'translateY(7px) rotate(45deg)' : '';
    bar2.style.opacity = open ? '0' : '1';
    bar3.style.transform = open ? 'translateY(-7px) rotate(-45deg)' : '';
  });

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      open = false;
      mobileMenu.style.opacity = '0';
      mobileMenu.style.pointerEvents = 'none';
      bar1.style.transform = '';
      bar2.style.opacity = '1';
      bar3.style.transform = '';
    });
  });

  // ── Section active highlight ──
  const sectionIds = ['services', 'realisations', 'a-propos', 'outils', 'processus', 'faq'];
  const navLinks = document.querySelectorAll<HTMLElement>('.nav-link');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        navLinks.forEach(link => {
          if (link.getAttribute('href') === `#${id}`) {
            link.classList.add('is-active');
          } else {
            link.classList.remove('is-active');
          }
        });
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px', threshold: 0 });

  sectionIds.forEach(id => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });
</script>
