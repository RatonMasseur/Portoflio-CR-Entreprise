---
const traits = ['Réactif', 'Transparent', 'Passionné'];
---

<section id="a-propos" class="px-6 overflow-hidden">
  <div class="max-w-6xl mx-auto">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- Photo block -->
      <div class="relative" data-animate="fade-right">
        <!-- Monogramme décoratif -->
        <span class="absolute -top-8 -left-4 font-['Bricolage_Grotesque'] select-none pointer-events-none" style="font-size: clamp(6rem, 15vw, 12rem); font-weight: 700; color: rgba(32, 96, 216, 0.07); line-height: 1;">RC</span>

        <div class="relative aspect-[4/5] overflow-hidden" style="border: 1px solid var(--border-card); border-radius: 16px; background: linear-gradient(160deg, #e8e0d2, #d5c9b8);">
          <img
            src="/photo.webp"
            alt="Robin Ration — Développeur web freelance"
            class="w-full h-full object-cover"
          />
          <!-- Warm overlay subtle -->
          <div class="absolute inset-0 opacity-0 hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(to top, rgba(32, 96, 216, 0.12) 0%, transparent 60%);"></div>
        </div>

        <!-- Badge flottant -->
        <div class="absolute -bottom-5 -right-5 px-5 py-3 glass" style="border-radius: 12px;">
          <p class="label-tech" style="color: var(--text-muted); margin-bottom: 2px;">Basé en</p>
          <p class="font-['Bricolage_Grotesque'] font-bold text-sm" style="color: var(--text-primary);">Alsace</p>
        </div>
      </div>

      <!-- Text block -->
      <div data-animate="fade-left">
        <span class="section-label mb-5 block">À propos</span>
        <h2 class="font-['Bricolage_Grotesque'] leading-tight mb-8" style="font-size: var(--type-h2); font-weight: 700;">
          Robin,<br />
          développeur web<br />
          <span style="color: var(--accent-primary);">indépendant.</span>
        </h2>

        <div class="space-y-5 text-base leading-relaxed mb-8" style="color: var(--text-secondary);">
          <p>Je m'appelle Robin, développeur web basé en Alsace. Je travaille en direct avec chaque client — pas d'intermédiaire, pas de chef de projet, pas de délai gonflé.</p>
          <p>Ce que vous obtenez concrètement : un interlocuteur unique du brief à la mise en ligne, une réponse sous 24h, et un site conçu spécifiquement pour votre métier et votre ville.</p>
        </div>

        <!-- Citation directe — serif organique -->
        <blockquote class="relative pl-5 mb-10" style="border-left: 2px solid var(--accent-primary);">
          <p class="quote-serif text-lg" style="color: var(--text-secondary);">
            "Je construis des sites qui travaillent pour vous, pas l'inverse."
          </p>
        </blockquote>

        <!-- Traits -->
        <div class="flex flex-wrap gap-2 mb-10">
          {traits.map(trait => (
            <span
              class="px-4 py-2 text-sm font-['Bricolage_Grotesque'] font-semibold tracking-wide glass"
              style="border-radius: 100px; color: var(--accent-deep);"
            >
              {trait}
            </span>
          ))}
        </div>

        <a href="#contact" class="btn-outline inline-flex">
          <span class="btn-text-front">Travaillons ensemble</span>
          <span class="btn-text-back">Travaillons ensemble</span>
        </a>
      </div>
    </div>
  </div>
</section>
