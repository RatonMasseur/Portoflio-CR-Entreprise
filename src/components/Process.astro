---
const steps = [
  { number: '01', title: 'Échange', description: 'On discute de votre activité, vos clients cibles, ce que vous voulez mettre en avant.' },
  { number: '02', title: 'Maquette', description: "Je vous présente une maquette complète. On ajuste ensemble jusqu'à ce que ce soit parfait." },
  { number: '03', title: 'Développement', description: "Je code le site, j'optimise le SEO, je configure l'hébergement. Vous ne touchez à rien." },
  { number: '04', title: 'Mise en ligne', description: 'Votre site est en ligne. Je vous forme en 30 min à gérer votre contenu vous-même.' }
];
---

<section id="processus" class="py-32 md:py-20 px-6">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-20" data-animate="fade-up">
      <div>
        <span class="section-label mb-4 block">Processus</span>
        <h2 class="font-['Syne'] leading-tight" style="font-size: var(--type-h2); font-weight: 800;">Comment ça<br />se passe ?</h2>
      </div>
      <p class="max-w-xs text-sm" style="color: var(--text-muted);">Un process simple et transparent, du brief à la mise en ligne.</p>
    </div>

    <!-- Desktop: horizontal timeline -->
    <div class="hidden md:grid grid-cols-4 gap-8 relative">
      <!-- Ligne de connexion — animée via GSAP scaleX 0→1 -->
      <div id="process-line" class="absolute top-[19px] left-[calc(12.5%+20px)] right-[calc(12.5%+20px)] h-px" style="background: linear-gradient(to right, var(--accent-primary), var(--border-card)); transform-origin: left; transform: scaleX(0);"></div>

      {steps.map((step, i) => (
        <div class="relative" data-animate="fade-up" data-animate-delay={i * 120}>
          <!-- Numéro cercle -->
          <div
            class="w-10 h-10 rounded-full flex items-center justify-center mb-6 relative z-10 font-['Syne'] font-bold text-xs"
            style="background: var(--bg-primary); border: 1px solid var(--accent-primary); color: var(--accent-primary);"
          >
            {step.number}
          </div>
          <h3 class="text-lg font-['Syne'] font-bold mb-2" style="color: var(--text-primary);">{step.title}</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">{step.description}</p>
        </div>
      ))}
    </div>

    <!-- Mobile: vertical timeline -->
    <div class="md:hidden flex flex-col gap-0 relative">
      {steps.map((step, i) => (
        <div class="relative flex gap-6 pb-10 last:pb-0" data-animate="fade-up" data-animate-delay={i * 100}>
          <!-- Ligne verticale -->
          {i < steps.length - 1 && (
            <div class="absolute left-[19px] top-10 bottom-0 w-px" style="background: linear-gradient(to bottom, var(--accent-primary), var(--border-card));"></div>
          )}
          <!-- Cercle -->
          <div
            class="w-10 h-10 shrink-0 rounded-full flex items-center justify-center font-['Syne'] font-bold text-xs relative z-10"
            style="background: var(--bg-primary); border: 1px solid var(--accent-primary); color: var(--accent-primary);"
          >
            {step.number}
          </div>
          <div class="pt-1.5">
            <h3 class="text-base font-['Syne'] font-bold mb-1" style="color: var(--text-primary);">{step.title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">{step.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
