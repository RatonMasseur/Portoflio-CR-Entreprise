---
import ProcessCards from './ProcessCards.tsx';

const mobileSteps = [
  { tag: 'Étape 01', title: 'Échange',       desc: "On discute de votre activité, vos clients cibles, ce que vous voulez mettre en avant. 30 minutes suffisent.", bg: '#0f0d0a' },
  { tag: 'Étape 02', title: 'Maquette',      desc: "Je vous présente une maquette complète du site. On ajuste ensemble jusqu'à ce que ce soit parfait.",          bg: '#0d1420' },
  { tag: 'Étape 03', title: 'Développement', desc: "Je code le site à la main, optimise le SEO, configure l'hébergement. Vous ne touchez à rien.",                bg: '#0b1626' },
  { tag: 'Étape 04', title: 'Mise en ligne', desc: 'Votre site est en ligne. Je vous forme en 30 minutes à gérer votre contenu — et je reste disponible.',         bg: '#09182e' },
];
---

<section id="processus" style="background: var(--bg-primary); overflow-x: clip;">

  <!-- Header (flux normal) -->
  <div class="max-w-3xl mx-auto px-6 pt-32 md:pt-20 pb-16" data-animate="fade-up">
    <span class="section-label mb-4 block">Processus</span>
    <h2 class="font-['Bricolage_Grotesque'] leading-tight" style="font-size: var(--type-h2); font-weight: 700; color: var(--text-primary);">
      Comment ça<br />
      <span style="color: var(--accent-primary);">se passe ?</span>
    </h2>
    <p class="mt-4 text-base max-w-sm" style="color: var(--text-muted);">Un process simple et transparent, du brief à la mise en ligne en 7 jours.</p>
  </div>

  <!-- Stacking cards — desktop (motion/react scroll) -->
  <div class="hidden md:block">
    <ProcessCards client:only="react" />
  </div>

  <!-- Mobile: vertical simple -->
  <div class="md:hidden max-w-3xl mx-auto px-6 pb-20 flex flex-col gap-4">
    {mobileSteps.map((step, i) => (
      <div
        class="rounded-2xl p-8"
        style={`background: ${step.bg};`}
        data-animate="fade-up"
        data-animate-delay={i * 80}
      >
        <span class="label-tech mb-3 block" style="color: rgba(91,150,245,0.65);">{step.tag}</span>
        <h3 class="font-['Bricolage_Grotesque'] font-bold mb-3" style="font-size: var(--type-h3); color: #ffffff;">{step.title}</h3>
        <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.55);">{step.desc}</p>
      </div>
    ))}
  </div>

</section>
