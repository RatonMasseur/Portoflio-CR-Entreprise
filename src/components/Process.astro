---
const steps = [
  {
    tag: 'Étape 01',
    title: 'Échange',
    description: "On discute de votre activité, vos clients cibles, ce que vous voulez mettre en avant. 30 minutes suffisent.",
    details: ['Appel découverte gratuit', 'Cahier des charges simple', 'Devis sous 24h'],
    bg: '#0f0d0a',
    numColor: 'rgba(32,96,216,0.07)',
  },
  {
    tag: 'Étape 02',
    title: 'Maquette',
    description: "Je vous présente une maquette complète du site. On ajuste ensemble jusqu'à ce que ce soit parfait.",
    details: ['Maquette Figma interactive', 'Révisions illimitées', 'Validation avant développement'],
    bg: '#0d1420',
    numColor: 'rgba(32,96,216,0.07)',
  },
  {
    tag: 'Étape 03',
    title: 'Développement',
    description: "Je code le site à la main, optimise le SEO, configure l'hébergement. Vous ne touchez à rien.",
    details: ['Code propre & performant', 'SEO technique inclus', 'Tests mobile & desktop'],
    bg: '#0b1626',
    numColor: 'rgba(91,150,245,0.08)',
  },
  {
    tag: 'Étape 04',
    title: 'Mise en ligne',
    description: 'Votre site est en ligne. Je vous forme en 30 minutes à gérer votre contenu — et je reste disponible.',
    details: ['Déploiement & DNS', 'Formation contenu incluse', 'Support 3 mois offert'],
    bg: '#09182e',
    numColor: 'rgba(91,150,245,0.1)',
  }
];

const PEEK = 80;   // px visibles du header de chaque carte en-dessous
const BASE = 100;  // px depuis le haut du viewport pour la première carte
---

<section id="processus" class="px-6" style="background: var(--bg-primary); overflow-x: clip;">

  <!-- Header (flux normal) -->
  <div class="max-w-3xl mx-auto pt-32 md:pt-20 pb-16" data-animate="fade-up">
    <span class="section-label mb-4 block">Processus</span>
    <h2 class="font-['Bricolage_Grotesque'] leading-tight" style="font-size: var(--type-h2); font-weight: 700; color: var(--text-primary);">
      Comment ça<br />
      <span class="font-['Fraunces'] italic" style="font-weight: 300; color: var(--accent-primary);">se passe ?</span>
    </h2>
    <p class="mt-4 text-base max-w-sm" style="color: var(--text-muted);">Un process simple et transparent, du brief à la mise en ligne en 7 jours.</p>
  </div>

  <!-- Stacking cards — desktop -->
  <div class="hidden md:block max-w-3xl mx-auto relative" style={`padding-bottom: ${BASE + steps.length * PEEK + 60}px;`}>
    {steps.map((step, i) => (
      <div class="step-scroll-slot">
        <div
          class="step-card process-card"
          style={`top: ${BASE + i * PEEK}px; z-index: ${10 + i}; background: ${step.bg};`}
        >
          <!-- Header visible (peek area) -->
          <div class="step-header">
            <span class="step-tag" style="color: rgba(91,150,245,0.65);">{step.tag}</span>
            <h3 class="step-title font-['Bricolage_Grotesque'] font-bold leading-tight" style={`font-size: var(--type-h3); color: #ffffff;`}>
              {step.title}
            </h3>
          </div>

          <!-- Body (covered by next card) -->
          <div class="step-body">
            <p class="text-sm leading-relaxed mb-8" style="color: rgba(255,255,255,0.55);">{step.description}</p>
            <ul class="flex flex-col gap-3">
              {step.details.map(d => (
                <li class="flex items-center gap-3 text-sm" style="color: rgba(255,255,255,0.45);">
                  <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background: rgba(91,150,245,0.6);"></span>
                  {d}
                </li>
              ))}
            </ul>
          </div>

          <!-- Numéro décoratif -->
          <div class="step-deco-num" style={`color: ${step.numColor};`}>{step.tag.split(' ')[1]}</div>
        </div>
      </div>
    ))}
  </div>

  <!-- Mobile: vertical simple -->
  <div class="md:hidden max-w-3xl mx-auto pb-20 flex flex-col gap-4">
    {steps.map((step, i) => (
      <div
        class="rounded-2xl p-8"
        style={`background: ${step.bg};`}
        data-animate="fade-up"
        data-animate-delay={i * 80}
      >
        <span class="label-tech mb-3 block" style="color: rgba(91,150,245,0.65);">{step.tag}</span>
        <h3 class="font-['Bricolage_Grotesque'] font-bold mb-3" style={`font-size: var(--type-h3); color: #ffffff;`}>{step.title}</h3>
        <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.55);">{step.description}</p>
      </div>
    ))}
  </div>

</section>

<style>
  /* ── Slot de scroll : donne la hauteur pour que la carte sticky "avance" ── */
  .step-scroll-slot {
    height: 70vh;
    position: relative;
  }

  /* ── Carte sticky ── */
  .step-card {
    position: sticky;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
    box-shadow: 0 24px 64px rgba(0,0,0,0.4);
    will-change: transform;
  }

  /* Header : toujours visible (zone de peek) */
  .step-header {
    padding: 28px 48px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .step-tag {
    display: block;
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 0.8rem;
    font-weight: 300;
    letter-spacing: -0.01em;
    margin-bottom: 6px;
  }

  .step-title {
    margin: 0;
  }

  /* Body : description + bullets */
  .step-body {
    padding: 28px 48px 40px;
    position: relative;
    z-index: 1;
  }

  /* Transform origin pour l'effet scale depuis le haut */
  .step-card {
    transform-origin: top center;
  }

  /* Grand numéro décoratif en fond */
  .step-deco-num {
    position: absolute;
    right: -12px;
    bottom: -24px;
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 800;
    font-size: clamp(100px, 16vw, 180px);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const cards = Array.from(document.querySelectorAll<HTMLElement>('.process-card'));
  const total = cards.length;

  // Sync avec Lenis si disponible
  const lenis = (window as any).__lenis;
  if (lenis) {
    lenis.on('scroll', ScrollTrigger.update);
  }

  // Chaque carte sauf la dernière rétrécit quand la suivante arrive
  cards.forEach((card, i) => {
    if (i === total - 1) return;

    const targetScale = 1 - (total - i) * 0.05;
    const nextCard = cards[i + 1];

    gsap.to(card, {
      scale: targetScale,
      ease: 'none',
      scrollTrigger: {
        trigger: nextCard,
        start: 'top bottom',
        end: 'top center',
        scrub: true,
      },
    });
  });
</script>
