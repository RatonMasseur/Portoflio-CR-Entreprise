<section id="contact" class="px-6 relative" style="background: linear-gradient(to bottom, #ffffff 0%, #ffffff 28%, #0a0806 82%);">

  <div class="max-w-2xl mx-auto relative">

    <div class="text-center mb-12" data-animate="fade-up">
      <span class="section-label mb-4 block">Contact</span>
      <h2 class="font-['Bricolage_Grotesque'] leading-tight mb-4" style="font-size: var(--type-h2); font-weight: 700; color: var(--text-primary);">Prêt à lancer<br /><span style="color: var(--accent-primary);">votre projet ?</span></h2>
      <p style="color: var(--text-secondary);">Décrivez-moi votre projet. Réponse sous 24h.</p>
    </div>

    <!-- Encart clair -->
    <div class="contact-card" data-animate="fade-up">

      <!-- Header encart -->
      <div class="contact-card-header">
        <div class="flex items-center gap-3 mb-1">
          <div class="w-2 h-2 rounded-full" style="background: var(--accent-primary); box-shadow: 0 0 8px rgba(32,96,216,0.5);"></div>
          <span class="label-tech" style="color: var(--text-muted);">Disponible pour nouveaux projets</span>
        </div>
        <p class="text-sm" style="color: var(--text-secondary);">Réponse garantie sous 24h · Devis gratuit</p>
      </div>

      <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="name" class="label-tech block mb-2" style="color: var(--text-muted);">Nom</label>
            <input
              type="text" id="name" name="name" required
              class="w-full px-4 py-3.5 contact-input"
              placeholder="Votre nom"
            />
          </div>
          <div>
            <label for="email" class="label-tech block mb-2" style="color: var(--text-muted);">Email</label>
            <input
              type="email" id="email" name="email" required
              class="w-full px-4 py-3.5 contact-input"
              placeholder="votre@email.com"
            />
          </div>
        </div>
        <div>
          <label for="message" class="label-tech block mb-2" style="color: var(--text-muted);">Votre projet</label>
          <textarea
            id="message" name="message" rows="5" required
            class="w-full px-4 py-3.5 contact-input resize-none"
            placeholder="Décrivez votre projet, votre métier, ce que vous attendez..."
          ></textarea>
        </div>
        <button type="submit" class="btn-primary w-full justify-center text-base py-4">
          <span class="btn-text-front">Envoyer ma demande</span>
          <span class="btn-text-back">Envoyer ma demande</span>
        </button>
      </form>
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mt-8 text-sm" data-animate="fade-up">
      <div class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full" style="background: var(--accent-light);"></span>
        <span class="label-tech" style="color: rgba(255,255,255,0.4);">Alsace · Partout en France</span>
      </div>
      <div class="hidden sm:block w-px h-4" style="background: rgba(255,255,255,0.1);"></div>
      <div class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full" style="background: var(--accent-light);"></span>
        <span class="label-tech" style="color: rgba(255,255,255,0.4);">Réponse sous 24h garantie</span>
      </div>
    </div>

  </div>
</section>

