<section id="contact" class="py-32 md:py-20 px-6 relative overflow-hidden">
  <!-- Glow ambiant -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[500px] rounded-full blur-[130px] pointer-events-none" style="background: radial-gradient(ellipse, rgba(232, 164, 74, 0.1) 0%, transparent 70%);"></div>

  <div class="max-w-2xl mx-auto relative">

    <div class="text-center mb-12" data-animate="fade-up">
      <span class="section-label mb-4 block">Contact</span>
      <h2 class="font-['Bricolage_Grotesque'] leading-tight mb-4" style="font-size: var(--type-h2); font-weight: 700;">Prêt à lancer<br />votre projet ?</h2>
      <p style="color: var(--text-secondary);">Décrivez-moi votre projet. Réponse sous 24h.</p>
    </div>

    <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-4 glass p-8" style="border-radius: 20px;" data-animate="fade-up">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="name" class="label-tech block mb-2">Nom</label>
          <input
            type="text" id="name" name="name" required
            class="w-full px-4 py-3.5 border transition-colors"
            style="background: rgba(255,255,255,0.6); border-color: var(--border-card); border-radius: 10px; font-size: 0.95rem; color: var(--text-primary);"
            placeholder="Votre nom"
          />
        </div>
        <div>
          <label for="email" class="label-tech block mb-2">Email</label>
          <input
            type="email" id="email" name="email" required
            class="w-full px-4 py-3.5 border transition-colors"
            style="background: rgba(255,255,255,0.6); border-color: var(--border-card); border-radius: 10px; font-size: 0.95rem; color: var(--text-primary);"
            placeholder="votre@email.com"
          />
        </div>
      </div>
      <div>
        <label for="message" class="label-tech block mb-2">Votre projet</label>
        <textarea
          id="message" name="message" rows="5" required
          class="w-full px-4 py-3.5 border transition-colors resize-none"
          style="background: rgba(255,255,255,0.6); border-color: var(--border-card); border-radius: 10px; font-size: 0.95rem; color: var(--text-primary);"
          placeholder="Décrivez votre projet, votre métier, ce que vous attendez..."
        ></textarea>
      </div>
      <button type="submit" class="btn-primary w-full justify-center text-base py-4">
        Envoyer ma demande →
      </button>
    </form>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mt-8 text-sm" data-animate="fade-up">
      <div class="flex items-center gap-2" style="color: var(--text-muted);">
        <span class="w-1.5 h-1.5 rounded-full" style="background: var(--accent-primary);"></span>
        <span class="label-tech">Alsace · Partout en France</span>
      </div>
      <div class="hidden sm:block w-px h-4" style="background: var(--border-card);"></div>
      <div class="flex items-center gap-2" style="color: var(--text-muted);">
        <span class="w-1.5 h-1.5 rounded-full" style="background: var(--accent-primary);"></span>
        <span class="label-tech">Réponse sous 24h garantie</span>
      </div>
    </div>

  </div>
</section>
