---
const items = [
  'Astro', 'React', 'Tailwind CSS', 'WordPress',
  'SEO Local', 'Figma', 'TypeScript', 'Performance', 'Responsive Design', 'GSAP'
];
const allItems = [...items, ...items];
---

<div class="py-6 overflow-hidden" style="border-top: 1px solid var(--border-card); border-bottom: 1px solid var(--border-card);">
  <div class="marquee-track flex gap-10 whitespace-nowrap hover:[animation-play-state:paused]">
    {allItems.map(item => (
      <span class="flex items-center gap-10 shrink-0">
        <span class="label-tech">{item}</span>
        <span style="color: var(--accent-primary); font-size: 0.5rem;">◆</span>
      </span>
    ))}
  </div>
</div>

<style>
  .marquee-track {
    animation: marquee 35s linear infinite;
    width: max-content;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
