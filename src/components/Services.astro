---
const services = [
  {
    title: 'Création de site web',
    description: 'Site vitrine moderne, rapide et optimisé pour convertir vos visiteurs en clients. Conçu sur-mesure pour votre métier.',
    span: 'col-span-1 md:col-span-2',
    lottieSrc: '/animations/web.lottie',
  },
  {
    title: 'Design responsive',
    description: "Votre site s'adapte parfaitement sur mobile, tablette et desktop. Testé sur tous les appareils.",
    span: 'col-span-1',
    lottieSrc: '/animations/responsive.lottie',
  },
  {
    title: 'SEO local',
    description: 'Apparaissez en premier quand vos clients vous cherchent sur Google. Configuration Google Business incluse.',
    span: 'col-span-1',
    lottieSrc: '/animations/seo.lottie',
  },
  {
    title: 'Performance & maintenance',
    description: "Site rapide, sécurisé et maintenu. Vous n'avez rien à gérer — je m'occupe de tout.",
    span: 'col-span-1 md:col-span-2',
    lottieSrc: '/animations/perf.lottie',
  },
];
---

<section id="services" class="py-32 md:py-20 px-6">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16" data-animate="fade-up">
      <div>
        <span class="section-label mb-4 block">Services</span>
        <h2 class="font-['Bricolage_Grotesque'] leading-tight" style="font-size: var(--type-h2); font-weight: 700;">Ce que je peux<br />faire pour vous</h2>
      </div>
      <p class="max-w-xs text-base" style="color: var(--text-muted);">Tout ce qu'il faut pour être visible et crédible en ligne. Rien de superflu.</p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {services.map((service, i) => (
        <div
          class={`bento-card bento-dark ${service.span}`}
          data-animate="fade-up"
          data-animate-delay={i * 80}
        >
          <!-- Lottie animation -->
          <div class="mb-6">
            <canvas
              data-lottie-src={service.lottieSrc}
              width="80"
              height="80"
            ></canvas>
          </div>

          <!-- Content -->
          <h3 class="font-['Bricolage_Grotesque'] font-semibold mb-3" style="font-size: var(--type-h3); color: #ffffff;">
            {service.title}
          </h3>
          <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.5);">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .bento-dark {
    background: rgba(15, 13, 10, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .bento-dark:hover {
    border-color: rgba(184, 116, 24, 0.35);
    box-shadow: 0 0 40px rgba(232, 164, 74, 0.08);
  }
</style>
