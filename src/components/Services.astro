---
const services = [
  {
    number: '01',
    title: 'Création de site web',
    description: 'Site vitrine moderne, rapide et optimisé pour convertir vos visiteurs en clients. Conçu sur-mesure pour votre métier.'
  },
  {
    number: '02',
    title: 'Design responsive',
    description: "Votre site s'adapte parfaitement sur mobile, tablette et desktop. Testé sur tous les appareils."
  },
  {
    number: '03',
    title: 'SEO local',
    description: 'Apparaissez en premier quand vos clients vous cherchent sur Google. Configuration Google Business incluse.'
  },
  {
    number: '04',
    title: 'Performance & maintenance',
    description: "Site rapide, sécurisé et maintenu. Vous n'avez rien à gérer — je m'occupe de tout."
  }
];
---

<section id="services" class="py-32 md:py-20 px-6">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16" data-animate="fade-up">
      <div>
        <span class="section-label mb-4 block">Services</span>
        <h2 class="font-['Syne'] leading-tight" style="font-size: var(--type-h2); font-weight: 800;">Ce que je peux<br />faire pour vous</h2>
      </div>
      <p class="max-w-xs text-base" style="color: var(--text-muted);">Tout ce qu'il faut pour être visible et crédible en ligne. Rien de superflu.</p>
    </div>

    <!-- Services list — numbered, editorial -->
    <div class="divide-y" style="border-top: 1px solid var(--border-card); border-bottom: 1px solid var(--border-card);">
      {services.map((service, i) => (
        <div
          class="group grid grid-cols-[auto_1fr_auto] items-center gap-8 py-8 cursor-default transition-all duration-300 hover:pl-4"
          data-animate="fade-up"
          data-animate-delay={i * 80}
          style="border-color: var(--border-card);"
        >
          <!-- Number -->
          <span class="label-tech group-hover:text-[var(--accent-primary)] transition-colors duration-300">
            {service.number}
          </span>

          <!-- Content -->
          <div class="min-w-0">
            <h3 class="text-xl md:text-2xl font-['Syne'] font-bold mb-1 transition-colors duration-300 group-hover:text-[var(--accent-primary)]">
              {service.title}
            </h3>
            <p class="text-sm leading-relaxed max-w-lg" style="color: var(--text-muted);">{service.description}</p>
          </div>

          <!-- Arrow -->
          <span class="text-xl opacity-0 group-hover:opacity-100 transition-all duration-300 -translate-x-2 group-hover:translate-x-0" style="color: var(--accent-primary);">→</span>
        </div>
      ))}
    </div>
  </div>
</section>
