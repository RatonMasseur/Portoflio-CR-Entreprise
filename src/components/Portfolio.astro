---
const projects = [
  {
    id: 'paysagiste',
    title: 'Paysagiste · Mulhouse',
    description: 'Site vitrine WordPress avec galerie avant/après et SEO local optimisé pour capter les clients de la région.',
    type: 'Site Vitrine',
    href: '#',
    image: '/images/project-paysagiste.webp',
  },
  {
    id: 'electricien',
    title: 'Électricien · Colmar',
    description: 'Landing page statique ultra-rapide axée génération de leads avec formulaire de devis intégré.',
    type: 'Landing Page',
    href: '#',
    image: '/images/project-electricien.webp',
  },
  {
    id: 'fleuriste',
    title: 'Fleuriste · Strasbourg',
    description: 'Site vitrine WordPress avec boutique en ligne et SEO local pour développer la visibilité.',
    type: 'E-Commerce',
    href: '#',
    image: '/images/project-fleuriste.webp',
  },
  {
    id: 'charpentier',
    title: 'Charpentier · Colmar',
    description: 'Site vitrine statique avec galerie de projets et formulaire de contact pour une présence en ligne soignée.',
    type: 'Site Vitrine',
    href: '#',
    image: '/images/project-charpentier.webp',
  },
  {
    id: 'coiffeur',
    title: 'Coiffeur · Strasbourg',
    description: 'Site vitrine avec galerie de prestations, tarifs et prise de rendez-vous en ligne intégrée.',
    type: 'Landing Page',
    href: '#',
    image: '/images/project-electricien.webp',
  },
  {
    id: 'boulanger',
    title: 'Artisan Boucher · Mulhouse',
    description: 'Site vitrine artisanal avec carte des produits, horaires et formulaire de commande personnalisé.',
    type: 'Site Vitrine',
    href: '#',
    image: '/images/project-paysagiste.webp',
  },
];
---

<section id="realisations" class="py-32 md:py-20">

  <!-- Header : titre + flèches -->
  <div class="max-w-6xl mx-auto px-6 mb-14 flex items-end justify-between" data-animate="fade-up">
    <div class="flex flex-col gap-3">
      <span class="section-label">Réalisations</span>
      <h2 class="font-['Bricolage_Grotesque'] leading-tight" style="font-size: var(--type-h2); font-weight: 700;">Des sites qui font<br /><span style="color: var(--accent-primary);">la différence</span></h2>
      <p class="max-w-xs text-sm mt-1" style="color: var(--text-muted);">Démos représentatives — les vraies réalisations arrivent dès les premiers clients.</p>
    </div>
    <div class="hidden md:flex gap-3 mb-2">
      <button id="portfolio-prev" class="carousel-arrow" aria-label="Précédent">←</button>
      <button id="portfolio-next" class="carousel-arrow" aria-label="Suivant">→</button>
    </div>
  </div>

  <!-- Carousel full width -->
  <div class="embla-portfolio overflow-hidden" id="portfolio-carousel">
    <div class="embla-portfolio__container flex" style="margin-left: max(24px, calc(50vw - 600px + 24px));">
      {projects.map((project) => (
        <div class="embla-portfolio__slide pl-5" style="width: 360px; min-width: 360px; flex: 0 0 360px;">
          <a href={project.href} class="portfolio-card group block rounded-2xl overflow-hidden relative" style="min-height: 27rem; display: block;">
            <img
              src={project.image}
              alt={project.title}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <!-- gradient overlay -->
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);"></div>
            <!-- content -->
            <div class="absolute inset-x-0 bottom-0 p-7" style="color: #fff;">
              <span class="label-tech mb-3 inline-block" style="color: rgba(255,255,255,0.6);">{project.type}</span>
              <h3 class="font-['Bricolage_Grotesque'] font-semibold text-xl mb-2">{project.title}</h3>
              <p class="text-sm mb-6 line-clamp-2" style="color: rgba(255,255,255,0.65);">{project.description}</p>
              <span class="flex items-center gap-2 text-sm font-medium" style="color: var(--accent-light);">
                Voir le projet
                <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
              </span>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>

  <!-- Dots -->
  <div id="portfolio-dots" class="mt-8 flex justify-center gap-2"></div>

</section>

<style>
  .portfolio-card {
    transition: box-shadow 0.3s ease;
    position: relative;
  }
  .portfolio-card:hover {
    box-shadow: 0 20px 60px rgba(91, 150, 245, 0.3);
  }

  .carousel-arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(0,0,0,0.12);
    background: transparent;
    color: var(--text-primary);
    cursor: pointer;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s;
  }
  .carousel-arrow:hover {
    background: rgba(0,0,0,0.05);
  }
  .carousel-arrow:disabled {
    opacity: 0.3;
    cursor: default;
  }
</style>

<script>
  import EmblaCarousel from 'embla-carousel';

  const container = document.getElementById('portfolio-carousel') as HTMLElement;
  const embla = EmblaCarousel(container, { align: 'start', loop: false });

  const prevBtn = document.getElementById('portfolio-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('portfolio-next') as HTMLButtonElement;

  prevBtn?.addEventListener('click', () => embla.scrollPrev());
  nextBtn?.addEventListener('click', () => embla.scrollNext());

  // Dots
  const dotsEl = document.getElementById('portfolio-dots')!;
  const snaps = embla.scrollSnapList();

  snaps.forEach((_, i) => {
    const dot = document.createElement('button');
    dot.className = 'portfolio-dot';
    dot.setAttribute('aria-label', `Aller au projet ${i + 1}`);
    dot.style.cssText = `width:8px;height:8px;border-radius:50%;border:none;cursor:pointer;transition:background 0.2s;background:${i === 0 ? 'var(--accent-primary)' : 'rgba(0,0,0,0.15)'};`;
    dot.addEventListener('click', () => embla.scrollTo(i));
    dotsEl.appendChild(dot);
  });

  const dots = dotsEl.querySelectorAll<HTMLElement>('.portfolio-dot');

  const updateDots = () => {
    const current = embla.selectedScrollSnap();
    dots.forEach((dot, i) => {
      dot.style.background = i === current ? 'var(--accent-primary)' : 'rgba(0,0,0,0.15)';
    });
  };

  const updateArrows = () => {
    if (prevBtn) prevBtn.disabled = !embla.canScrollPrev();
    if (nextBtn) nextBtn.disabled = !embla.canScrollNext();
  };

  embla.on('select', updateDots);
  embla.on('select', updateArrows);
  updateArrows();
</script>
